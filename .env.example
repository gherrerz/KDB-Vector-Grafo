# Copy this file to '.env' and replace the value with your OpenAI API key
# Example:
# OPENAI_API_KEY=sk-xxxxxx

OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Optional: specify model overrides
OPENAI_MODEL=text-embedding-3-small

# Neo4j (required for structural validation in hybrid RAG)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=YOUR_NEO4J_PASSWORD
NEO4J_DATABASE=neo4j